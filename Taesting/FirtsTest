import requests

BASE_URL = "http://127.0.0.1:5000"

def attempt_login(username, password):
    """Try to login and return result"""
    try:
        response = requests.post(
            f"{BASE_URL}/login",
            data={"username": username, "password": password},
            allow_redirects=False
        )
        
        if response.status_code == 302:  # Redirect = success
            return "Access Granted"
        elif response.status_code == 401:  # Unauthorized
            return "Access Denied"
        else:
            return f"HTTP {response.status_code}"
    except:
        return "Server Not Running"

# TEST 1: Wrong Password
def test_wrong_password():
    print("\n[TEST 1] Wrong Password Test")
    status = attempt_login("Moustafa", "wrong_password")
    print(f"Result: {status}")
    assert status == "Access Denied", "FAIL: Wrong password should be rejected"
    print("PASS")

# TEST 2: SQL Injection Attack
def test_sql_injection():
    print("\n[TEST 2] SQL Injection Test")
    status = attempt_login("' OR '1'='1' --", "anything")
    print(f"Result: {status}")
    assert status != "Access Granted", "CRITICAL: SQL Injection worked!"
    print("PASS")

# TEST 3: Empty Credentials
def test_empty_credentials():
    print("\n[TEST 3] Empty Credentials Test")
    status = attempt_login("", "")
    print(f"Result: {status}")
    assert status == "Access Denied", "FAIL: Empty credentials should be rejected"
    print("PASS")

# TEST 4: Correct Login
def test_correct_login():
    print("\n[TEST 4] Correct Login Test")
    status = attempt_login("jeremiah", "password123")
    print(f"Result: {status}")
    assert status == "Access Granted", "FAIL: Correct login should work"
    print("PASS")

# TEST 5: Direct Dashboard Access
def test_dashboard_access():
    print("\n[TEST 5] Dashboard Access Without Login")
    response = requests.get(f"{BASE_URL}/dashboard", allow_redirects=False)
    if response.status_code == 302:
        print("PASS: Redirects to login page")
    else:
        print(f"FAIL: Dashboard accessible (Status: {response.status_code})")

# Run all tests
def run_tests():
    print("\n" + "="*30)
    print("LOGIN SECURITY TESTS")
    print("="*30)
    
    # Check if server is running
    try:
        requests.get(BASE_URL)
        print("Server is running\n")
    except:
        print("Server not running! Start with: python app.py")
        return
    
    tests = [
        test_wrong_password,
        test_sql_injection,
        test_empty_credentials,
        test_correct_login,
        test_dashboard_access
    ]
    
    passed = 0
    for test in tests:
        try:
            test()
            passed += 1
        except AssertionError as e:
            print(e)
    
    print("\n" + "="*40)
    print(f"RESULTS: {passed}/{len(tests)} tests passed")
    
if __name__ == "__main__":
    print("Make sure Flask is running: python app.py")
    run_tests()